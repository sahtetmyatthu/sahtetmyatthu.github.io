---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 2em 0 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2em;
			}
			.hero h1 {
				margin: 0 0 0.3em;
			}
			.hero p {
				margin: 0 0 1em;
				color: rgb(var(--gray-dark));
				font-size: 1.05em;
				max-width: 520px;
			}
			.hero-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.hero-tags li {
				font-size: 0.78em;
				padding: 0.2em 0.65em;
				border-radius: 4px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.4em;
				margin-bottom: 1em;
			}
			.section-header h2 {
				font-size: 1.1em;
				margin: 0;
			}
			.section-header a {
				font-size: 0.85em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 3em;
			}
			.post-list li {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1em;
				padding: 0.55em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				font-weight: 500;
				color: var(--black);
				text-decoration: none;
			}
			.post-list a:hover {
				color: var(--accent);
				text-decoration: underline;
			}
			.post-date {
				font-size: 0.82em;
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}
			.no-posts {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin: 0 0 3em;
			}
			.project-grid {
				list-style: none;
				padding: 0;
				margin: 0 0 3em;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 1em;
			}
			.project-card {
				display: flex;
				flex-direction: column;
				gap: 0.4em;
				padding: 1em 1.1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				text-decoration: none;
				color: var(--black);
				transition: border-color 0.15s;
			}
			.project-card:hover {
				border-color: var(--accent);
				text-decoration: none;
			}
			.project-card h3 {
				font-size: 0.95em;
				margin: 0;
			}
			.project-card p {
				font-size: 0.83em;
				color: rgb(var(--gray-dark));
				margin: 0;
				line-height: 1.5;
				flex: 1;
			}
			.project-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3em;
				list-style: none;
				padding: 0;
				margin: 0.2em 0 0;
			}
			.project-tags li {
				font-size: 0.7em;
				padding: 0.15em 0.5em;
				border-radius: 3px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 480px) {
				.post-date {
					display: none;
				}
				.project-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1>Hi, I'm Ngasa 👋</h1>
				<p>
					Backend Developer & DevOps enthusiast. I write about Linux,
					Docker, Kubernetes, Cloud and Go — things I learn while
					building real systems.
				</p>
				<ul class="hero-tags">
					<li>Linux</li>
					<li>Docker</li>
					<li>Kubernetes</li>
					<li>Cloud</li>
					<li>Go</li>
					<li>DevOps</li>
				</ul>
			</section>

			<!-- Recent Posts -->
			<div class="section-header">
				<h2>Recent Posts</h2>
				<a href="/blog/">All posts →</a>
			</div>

			{
				posts.length > 0 ? (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.title}
								</a>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</li>
						))}
					</ul>
				) : (
					<p class="no-posts">
						No posts yet — add <code>.md</code> files to{" "}
						<code>src/content/blog/</code>
					</p>
				)
			}

			<!-- Projects -->
			<!-- <div class="section-header">
				<h2>Projects</h2>
				<a
					href="https://github.com/yourusername"
					target="_blank"
					rel="noopener"
				>
					GitHub →
				</a>
			</div>

			<ul class="project-grid">
				<li>
					<a
						href="https://github.com/yourusername/project-one"
						target="_blank"
						rel="noopener"
						class="project-card"
					>
						<h3>Project One</h3>
						<p>Short description of what this project does.</p>
						<ul class="project-tags">
							<li>Go</li>
							<li>Docker</li>
							<li>PostgreSQL</li>
						</ul>
					</a>
				</li>
				<li>
					<a
						href="https://github.com/yourusername/project-two"
						target="_blank"
						rel="noopener"
						class="project-card"
					>
						<h3>Project Two</h3>
						<p>Short description of what this project does.</p>
						<ul class="project-tags">
							<li>Bash</li>
							<li>Linux</li>
							<li>CI/CD</li>
						</ul>
					</a>
				</li>
				<li>
					<a
						href="https://github.com/yourusername/project-three"
						target="_blank"
						rel="noopener"
						class="project-card"
					>
						<h3>Project Three</h3>
						<p>Short description of what this project does.</p>
						<ul class="project-tags">
							<li>Go</li>
							<li>REST API</li>
						</ul>
					</a>
				</li>
			</ul> -->
		</main>
		<Footer />
	</body>
</html>
